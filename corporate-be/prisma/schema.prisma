generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                             String              @id @default(uuid())
  email                          String              @unique
  username                       String              @unique
  password                       String
  firstName                      String              @map("first_name")
  lastName                       String              @map("last_name")
  avatar                         String?
  phone                          String?
  status                         UserStatus          @default(ACTIVE)
  emailVerifiedAt                DateTime?           @map("email_verified_at")
  lastLoginAt                    DateTime?           @map("last_login_at")
  failedLoginAttempts            Int                 @default(0) @map("failed_login_attempts")
  lockedAt                       DateTime?           @map("locked_at")
  lockedReason                   String?             @map("locked_reason")
  passwordChangedAt              DateTime            @default(now()) @map("password_changed_at")
  mustChangePassword             Boolean             @default(true) @map("must_change_password")
  mfaEnabled                     Boolean             @default(false) @map("mfa_enabled")
  mfaSecret                      String?             @map("mfa_secret")
  mfaVerifiedAt                  DateTime?           @map("mfa_verified_at")
  createdAt                      DateTime            @default(now()) @map("created_at")
  updatedAt                      DateTime            @updatedAt @map("updated_at")
  deletedAt                      DateTime?           @map("deleted_at")
  contactSubmissions             ContactSubmission[]
  createdFiles                   File[]              @relation("FileCreator")
  logActivities                  LogActivity[]
  news_news_created_by_idTousers news[]              @relation("news_created_by_idTousers")
  news_news_updated_by_idTousers news[]              @relation("news_updated_by_idTousers")
  createdPages                   Page[]              @relation("PageCreator")
  updatedPages                   Page[]              @relation("PageUpdater")
  passwordHistories              PasswordHistory[]
  refreshTokens                  RefreshToken[]
  userRoles                      UserRole[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenId   String   @unique @map("token_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([token])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model PasswordHistory {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("password_histories")
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  slug            String           @unique
  description     String?
  isSystem        Boolean          @default(false) @map("is_system")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([slug])
  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  slug            String           @unique
  module          String
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]

  @@index([module])
  @@index([slug])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Setting {
  id          String      @id @default(uuid())
  key         String      @unique
  value       Json
  type        SettingType @default(STRING)
  group       String
  label       String
  description String?
  isPublic    Boolean     @default(false) @map("is_public")
  isSystem    Boolean     @default(false) @map("is_system")
  options     Json?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([group])
  @@index([key])
  @@index([isPublic])
  @@map("settings")
}

model Menu {
  id           BigInt       @id @default(autoincrement())
  parentId     BigInt?      @map("parent_id")
  sectionTitle String?      @map("section_title") @db.VarChar(191)
  sectionOrder Int          @default(0) @map("section_order")
  title        String       @db.VarChar(191)
  translations Json?
  slug         String?      @db.VarChar(191)
  url          String?      @db.VarChar(191)
  icon         String?      @db.VarChar(191)
  image        String?      @db.VarChar(191)
  description  String?      @db.VarChar(191)
  badge        String?      @db.VarChar(191)
  position     MenuPosition @default(HEADER)
  type         MenuType     @default(LINK)
  order        Int          @default(0)
  isActive     Boolean      @default(true) @map("is_active")
  openNewTab   Boolean      @default(false) @map("open_new_tab")
  cssClass     String?      @map("css_class") @db.VarChar(191)
  createdBy    String?      @map("created_by") @db.VarChar(191)
  updatedBy    String?      @map("updated_by") @db.VarChar(191)
  createdAt    DateTime?    @default(now()) @map("created_at")
  updatedAt    DateTime?    @updatedAt @map("updated_at")
  parent       Menu?        @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children     Menu[]       @relation("MenuHierarchy")

  @@index([parentId])
  @@index([position, order, isActive])
  @@map("menus")
}

model Page {
  id              String          @id @default(uuid())
  title           String
  titleEn         String?         @map("title_en")
  titleId         String?         @map("title_id")
  slug            String          @unique
  template        PageTemplate    @default(DEFAULT)
  metaTitle       String?         @map("meta_title")
  metaDescription String?         @map("meta_description")
  metaKeywords    String?         @map("meta_keywords")
  metaThumbnail   String?         @map("meta_thumbnail")
  ogImage         String?         @map("og_image")
  product         String?
  promo           String?
  source          String?
  noindex         Boolean         @default(false)
  nofollow        Boolean         @default(false)
  showNavbar      Boolean         @default(true) @map("show_navbar")
  showFooter      Boolean         @default(true) @map("show_footer")
  status          PageStatus      @default(DRAFT)
  publishedAt     DateTime?       @map("published_at")
  createdById     String          @map("created_by_id")
  updatedById     String?         @map("updated_by_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")
  components      PageComponent[]
  createdBy       User            @relation("PageCreator", fields: [createdById], references: [id])
  updatedBy       User?           @relation("PageUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([status])
  @@index([template])
  @@index([publishedAt])
  @@index([createdAt])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedAt])
  @@map("pages")
}

model PageComponent {
  id        String   @id @default(uuid())
  pageId    String   @map("page_id")
  type      String   @map("component_type")
  data      Json     @map("component_data")
  order     Int      @default(0)
  isVisible Boolean  @default(true) @map("is_visible")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([order])
  @@index([type])
  @@map("page_components")
}

model Career {
  id               String         @id @default(uuid())
  title            String
  slug             String         @unique
  department       String
  location         String
  employmentType   EmploymentType @default(FULL_TIME) @map("employment_type")
  description      String
  requirements     String
  responsibilities String
  benefits         String?
  salaryRange      String?        @map("salary_range")
  closingDate      DateTime?      @map("closing_date")
  status           CareerStatus   @default(OPEN)
  views            Int            @default(0)
  applications     Int            @default(0)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  deletedAt        DateTime?      @map("deleted_at")

  @@index([slug])
  @@index([department])
  @@index([status])
  @@index([closingDate])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("careers")
}

model Award {
  id              String    @id @default(uuid())
  title           String
  titleId         String?   @map("title_id")
  titleEn         String?   @map("title_en")
  slug            String    @unique
  description     String?
  descriptionId   String?   @map("description_id")
  descriptionEn   String?   @map("description_en")
  topLogo         String?   @map("top_logo")
  image           String?
  link            String?
  issuer          String
  year            Int
  issueDate       DateTime  @map("issue_date")
  position        Int       @default(0)
  isActive        Boolean   @default(true) @map("is_active")
  status          String    @default("ACTIVE")
  createdBy       String?   @map("created_by")
  updatedBy       String?   @map("updated_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  @@index([slug])
  @@index([year])
  @@index([position])
  @@index([issueDate])
  @@index([isActive])
  @@index([status])
  @@index([deletedAt])
  @@map("awards")
}

model ManagementCategory {
  id          String       @id
  name        String
  slug        String       @unique
  description String?
  position    Int          @default(0)
  is_active   Boolean      @default(true)
  createdBy   String?      @map("created_by")
  updatedBy   String?      @map("updated_by")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deleted_at  DateTime?
  managements Management[]

  @@index([slug])
  @@index([deleted_at])
  @@index([is_active])
  @@index([position])
  @@map("management_categories")
}

model Management {
  id                 String             @id
  categoryId         String             @map("category_id")
  name               String
  slug               String             @unique
  positionEn         String?            @map("position_en")
  positionId         String?            @map("position_id")
  description        String?
  photo              String?
  bioEn              String?            @map("bio_en")
  bioId              String?            @map("bio_id")
  email              String?
  phone              String?
  linkedin           String?
  order              Int                @default(0)
  is_active          Boolean            @default(true)
  createdBy          String?            @map("created_by")
  updatedBy          String?            @map("updated_by")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  deleted_at         DateTime?
  managementCategory ManagementCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([deleted_at])
  @@index([is_active])
  @@index([order])
  @@index([slug])
  @@map("managements")
}

model ContactSubmission {
  id        String           @id @default(uuid())
  userId    String?          @map("user_id")
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  type      ContactType      @default(GENERAL)
  status    SubmissionStatus @default(NEW)
  ipAddress String?          @map("ip_address")
  userAgent String?          @map("user_agent")
  readAt    DateTime?        @map("read_at")
  repliedAt DateTime?        @map("replied_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  deletedAt DateTime?        @map("deleted_at")
  user      User?            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("contact_submissions")
}

model LogActivity {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")
  action      String
  module      String
  recordId    String?   @map("record_id")
  oldData     Json?     @map("old_data")
  newData     Json?     @map("new_data")
  description String?
  metadata    Json?
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")
  user        User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([recordId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("log_activities")
}

model VisitorLog {
  id         String   @id @default(uuid())
  page       String
  referrer   String?
  userAgent  String?  @map("user_agent")
  ipAddress  String?  @map("ip_address")
  sessionId  String?  @map("session_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([page])
  @@index([createdAt])
  @@index([sessionId])
  @@map("visitor_logs")
}

model UrlRedirect {
  id         String    @id @default(uuid())
  fromUrl    String    @unique @map("from_url")
  toUrl      String    @map("to_url")
  statusCode Int       @default(301) @map("status_code")
  hits       Int       @default(0)
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([fromUrl])
  @@index([isActive])
  @@index([deletedAt])
  @@map("url_redirects")
}

model Folder {
  id        String    @id @default(uuid())
  parentId  String?   @map("parent_id")
  name      String
  slug      String
  path      String    @unique
  isPublic  Boolean   @default(false) @map("is_public")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  files     File[]
  parent    Folder?   @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[]  @relation("FolderHierarchy")

  @@index([parentId])
  @@index([path])
  @@index([deletedAt])
  @@map("folders")
}

model File {
  id            String    @id @default(uuid())
  folderId      String?   @map("folder_id")
  createdById   String    @map("created_by_id")
  name          String
  originalName  String    @map("original_name")
  mimeType      String    @map("mime_type")
  size          Int
  path          String
  url           String
  cloudProvider String?   @map("cloud_provider")
  cloudPath     String?   @map("cloud_path")
  cloudKey      String?   @map("cloud_key")
  thumbnail     String?
  thumbnails    Json?
  width         Int?
  height        Int?
  duration      Int?
  metadata      Json?
  downloads     Int       @default(0)
  isPublic      Boolean   @default(false) @map("is_public")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  createdBy     User      @relation("FileCreator", fields: [createdById], references: [id])
  folder        Folder?   @relation(fields: [folderId], references: [id])
  formSubmissionFiles FormSubmissionFile[]

  @@index([folderId])
  @@index([createdById])
  @@index([mimeType])
  @@index([path])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("files")
}

model ContactUs {
  id          String        @id @default(uuid())
  firstName   String        @map("first_name")
  lastName    String        @map("last_name")
  email       String
  phone       String?
  role        String?
  company     String?
  inquiryType InquiryType   @map("inquiry_type")
  subject     String        @default("")
  message     String
  status      ContactStatus @default(NEW)
  ipAddress   String?       @map("ip_address")
  userAgent   String?       @map("user_agent")
  readAt      DateTime?     @map("read_at")
  submittedAt DateTime      @default(now()) @map("submitted_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([email])
  @@index([inquiryType])
  @@index([status])
  @@index([submittedAt])
  @@index([createdAt])
  @@map("contact_us")
}

model FormModule {
  id                  String                  @id @default(uuid())
  businessUnit        BusinessUnit            @map("business_unit")
  slug                String
  name                String
  description         String?
  category            FormCategory
  handlingMode        FormHandlingMode        @default(SUBMISSION) @map("handling_mode")
  status              FormModuleStatus        @default(DRAFT)
  schemaVersion       Int                     @default(1) @map("schema_version")
  defaultLocale       String                  @default("id") @map("default_locale")
  publicPath          String?                 @map("public_path")
  sourceWebsite       String?                 @map("source_website")
  promoWebsite        String?                 @map("promo_website")
  leadSource          String?                 @map("lead_source")
  integrationProvider FormIntegrationProvider @default(INTERNAL) @map("integration_provider")
  integrationConfig   Json?                   @map("integration_config")
  submissionSettings  Json?                   @map("submission_settings")
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")
  deletedAt           DateTime?               @map("deleted_at")
  fields              FormField[]
  integrations        FormIntegrationConfig[]
  responseConfigs     FormResponseConfig[]
  rules               FormFieldRule[]
  steps               FormStep[]
  submissions         FormSubmission[]

  @@unique([businessUnit, slug])
  @@index([businessUnit])
  @@index([category])
  @@index([status])
  @@index([deletedAt])
  @@map("form_modules")
}

model FormStep {
  id           String     @id @default(uuid())
  formModuleId String     @map("form_module_id")
  key          String
  title        String
  description  String?
  actionLabel  String?    @map("action_label")
  stepNumber   Int        @map("step_number")
  isReviewStep Boolean    @default(false) @map("is_review_step")
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  fields       FormField[]
  formModule   FormModule @relation(fields: [formModuleId], references: [id], onDelete: Cascade)

  @@unique([formModuleId, key])
  @@unique([formModuleId, stepNumber])
  @@index([formModuleId])
  @@index([isActive])
  @@map("form_steps")
}

model FormField {
  id            String            @id @default(uuid())
  formModuleId  String            @map("form_module_id")
  formStepId    String?           @map("form_step_id")
  parentFieldId String?           @map("parent_field_id")
  key           String
  path          String
  label         String
  fieldType     FormFieldType     @map("field_type")
  placeholder   String?
  helpText      String?           @map("help_text")
  defaultValue  Json?             @map("default_value")
  validation    Json?
  uiConfig      Json?             @map("ui_config")
  payloadKey    String?           @map("payload_key")
  sortOrder     Int               @default(0) @map("sort_order")
  isRequired    Boolean           @default(false) @map("is_required")
  isActive      Boolean           @default(true) @map("is_active")
  isSystem      Boolean           @default(false) @map("is_system")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  childFields   FormField[]       @relation("FormFieldHierarchy")
  formModule    FormModule        @relation(fields: [formModuleId], references: [id], onDelete: Cascade)
  formStep      FormStep?         @relation(fields: [formStepId], references: [id], onDelete: SetNull)
  options       FormFieldOption[]
  parentField   FormField?        @relation("FormFieldHierarchy", fields: [parentFieldId], references: [id], onDelete: Cascade)
  sourceRules   FormFieldRule[]   @relation("FormFieldRuleSource")
  targetRules   FormFieldRule[]   @relation("FormFieldRuleTarget")

  @@unique([formModuleId, path])
  @@index([formModuleId])
  @@index([formStepId])
  @@index([parentFieldId])
  @@index([fieldType])
  @@index([isActive])
  @@map("form_fields")
}

model FormFieldOption {
  id          String    @id @default(uuid())
  fieldId     String    @map("field_id")
  value       String
  label       String
  description String?
  metadata    Json?
  sortOrder   Int       @default(0) @map("sort_order")
  isDefault   Boolean   @default(false) @map("is_default")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  field       FormField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fieldId, value])
  @@index([fieldId])
  @@index([isActive])
  @@map("form_field_options")
}

model FormFieldRule {
  id           String        @id @default(uuid())
  formModuleId String        @map("form_module_id")
  sourceFieldId String?      @map("source_field_id")
  targetFieldId String?      @map("target_field_id")
  ruleType     FormRuleType  @map("rule_type")
  condition    Json
  actionConfig Json          @map("action_config")
  sortOrder    Int           @default(0) @map("sort_order")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  formModule   FormModule    @relation(fields: [formModuleId], references: [id], onDelete: Cascade)
  sourceField  FormField?    @relation("FormFieldRuleSource", fields: [sourceFieldId], references: [id], onDelete: Cascade)
  targetField  FormField?    @relation("FormFieldRuleTarget", fields: [targetFieldId], references: [id], onDelete: Cascade)

  @@index([formModuleId])
  @@index([sourceFieldId])
  @@index([targetFieldId])
  @@index([ruleType])
  @@index([isActive])
  @@map("form_field_rules")
}

model FormResponseConfig {
  id             String           @id @default(uuid())
  formModuleId   String           @map("form_module_id")
  key            String
  responseType   FormResponseType @map("response_type")
  label          String?
  matchCondition Json?            @map("match_condition")
  pathTemplate   String           @map("path_template")
  queryTemplate  Json?            @map("query_template")
  sortOrder      Int              @default(0) @map("sort_order")
  isDefault      Boolean          @default(false) @map("is_default")
  isActive       Boolean          @default(true) @map("is_active")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
