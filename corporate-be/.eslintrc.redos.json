{
  "env": {
    "node": true,
    "es2022": true
  },
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["security"],
  "rules": {
    "security/detect-unsafe-regex": "error"
  },
  "ignorePatterns": [
    "dist",
    "node_modules",
    "coverage"
  ]
}
