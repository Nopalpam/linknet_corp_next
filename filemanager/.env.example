# ========================
# Server
# ========================
PORT=3000
NODE_ENV=production

# ========================
# AWS S3
# ========================
# Autentikasi menggunakan IRSA (production/EKS) atau AWS CLI profile (local).
# Tidak perlu mengisi AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
# Local dev: jalankan `aws configure` untuk menyimpan credentials di ~/.aws/credentials
AWS_REGION=ap-southeast-3
AWS_BUCKET_NAME=your-s3-bucket-name

# ========================
# CDN (CloudFront)
# ========================
# Provide host only (no https://)
CDN_URL=d24cmpzg3ht16e.cloudfront.net

# ========================
# Upload Configuration
# ========================
# Max file size in MB (default: 10)
MAX_FILE_SIZE_MB=10

# ========================
# CORS
# ========================
# Comma-separated list of allowed origins. Do not use * in production.
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ========================
# API Key Auth
# ========================
# Required in production.
API_KEY=your_secret_api_key_here
