// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTHENTICATION MODULE
// ============================================

model User {
  id                  String     @id @default(uuid())
  email               String     @unique
  username            String     @unique
  password            String
  firstName           String     @map("first_name")
  lastName            String     @map("last_name")
  avatar              String?
  phone               String?
  status              UserStatus @default(ACTIVE)
  emailVerifiedAt     DateTime?  @map("email_verified_at")
  lastLoginAt         DateTime?  @map("last_login_at")
  // MBSS2.0-008: Failed login attempt tracking & account lockout
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockedAt            DateTime?  @map("locked_at")
  lockedReason        String?    @map("locked_reason")
  // MBSS2.0-009: Password age tracking
  passwordChangedAt   DateTime   @default(now()) @map("password_changed_at")
  // MBSS2.0-010: First-time login password change
  mustChangePassword  Boolean    @default(true) @map("must_change_password")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  deletedAt           DateTime?  @map("deleted_at")

  // Relations
  userRoles          UserRole[]
  logActivities      LogActivity[]
  createdPages       Page[]              @relation("PageCreator")
  createdNews        News[]              @relation("NewsCreator")
  updatedNews        News[]              @relation("NewsUpdater")
  contactSubmissions ContactSubmission[]
  createdFiles       File[]              @relation("FileCreator")
  refreshTokens      RefreshToken[]
  passwordHistories  PasswordHistory[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenId   String   @unique @map("token_id") // UUID for token rotation tracking
  tokenHash String   @unique @map("token_hash") @db.Text // Hashed refresh token
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique @db.Text
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([token])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// MBSS2.0-011: Password history to prevent reuse of last 6 passwords
model PasswordHistory {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("password_histories")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Role {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([slug])
  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  module      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  rolePermissions RolePermission[]

  @@index([module])
  @@index([slug])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// ============================================
// CORE MODULE
// ============================================

model Setting {
  id          String      @id @default(uuid())
  key         String      @unique
  value       Json
  type        SettingType @default(STRING)
  group       String
  label       String
  description String?
  isPublic    Boolean     @default(false) @map("is_public")
  isSystem    Boolean     @default(false) @map("is_system") // Prevent deletion of system settings
  options     Json? // For select type: { options: ["option1", "option2"] }
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([group])
  @@index([key])
  @@index([isPublic])
  @@map("settings")
}

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  IMAGE
  SELECT
}

model Menu {
  id            BigInt        @id @default(autoincrement())
  parentId      BigInt?       @map("parent_id")
  sectionTitle  String?       @map("section_title") @db.VarChar(191)
  sectionOrder  Int           @default(0) @map("section_order")
  title         String        @db.VarChar(191)
  translations  Json?         // Multi-language support: { "id": { "title": "...", "slug": "...", "description": "..." }, "en": {...} }
  slug          String?       @db.VarChar(191)
  url           String?       @db.VarChar(191)
  icon          String?       @db.VarChar(191)
  image         String?       @db.VarChar(191)
  description   String?       @db.VarChar(191)
  badge         String?       @db.VarChar(191)
  position      MenuPosition  @default(HEADER)
  type          MenuType      @default(LINK)
  order         Int           @default(0)
  isActive      Boolean       @default(true) @map("is_active")
  openNewTab    Boolean       @default(false) @map("open_new_tab")
  cssClass      String?       @map("css_class") @db.VarChar(191)
  createdBy     String?       @map("created_by") @db.VarChar(191)
  updatedBy     String?       @map("updated_by") @db.VarChar(191)
  createdAt     DateTime?     @default(now()) @map("created_at")
  updatedAt     DateTime?     @updatedAt @map("updated_at")

  // Self-referencing relation for hierarchical structure
  parent   Menu?  @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Menu[] @relation("MenuHierarchy")

  @@index([parentId])
  @@index([position, order, isActive])
  @@map("menus")
}

enum MenuPosition {
  HEADER  @map("header")
  FOOTER  @map("footer")
  BOTH    @map("both")
}

enum MenuType {
  LINK     @map("link")
  DROPDOWN @map("dropdown")
  MEGA     @map("mega")
}

// ============================================
// CONTENT MODULE
// ============================================

model Page {
  id              String       @id @default(uuid())
  title           String
  slug            String       @unique
  template        PageTemplate @default(DEFAULT)
  metaTitle       String?      @map("meta_title")
  metaDescription String?      @map("meta_description") @db.Text
  metaKeywords    String?      @map("meta_keywords") @db.Text
  ogImage         String?      @map("og_image")
  status          PageStatus   @default(DRAFT)
  publishedAt     DateTime?    @map("published_at")
  createdById     String       @map("created_by_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  // Relations
  createdBy  User            @relation("PageCreator", fields: [createdById], references: [id], onDelete: Restrict)
  components PageComponent[]

  @@index([slug])
  @@index([status])
  @@index([template])
  @@index([publishedAt])
  @@index([createdAt])
  @@index([createdById])
  @@index([deletedAt])
  @@map("pages")
}

enum PageTemplate {
  DEFAULT
  FULL_WIDTH
  LANDING
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

model PageComponent {
  id        String   @id @default(uuid())
  pageId    String   @map("page_id")
  type      String   @map("component_type")
  data      Json     @map("component_data")
  order     Int      @default(0)
  isVisible Boolean  @default(true) @map("is_visible")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([order])
  @@index([type])
  @@map("page_components")
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ============================================
// NEWS MODULE
// ============================================

model News {
  id              String        @id @default(uuid())
  titleEn         String        @map("title_en")
  titleId         String?       @map("title_id")
  slug            String        @unique
  newsDate        DateTime      @map("news_date") @db.Date
  thumbnail       String?       @map("news_thumbnail")
  excerptEn       String?       @map("excerpt_en") @db.Text
  excerptId       String?       @map("excerpt_id") @db.Text
  contentEn       String        @map("content_en") @db.Text
  contentId       String?       @map("content_id") @db.Text
  newsLink        String?       @map("news_link")
  categoryId      String        @map("category_id")
  metaKeywords    String?       @map("meta_keywords") @db.Text
  customCss       String?       @map("custom_css") @db.Text
  customJs        String?       @map("custom_js") @db.Text
  viewCount       Int           @default(0) @map("view_count")
  viewCountUnique Int           @default(0) @map("view_count_unique")
  status          ContentStatus @default(DRAFT)
  publishedAt     DateTime?     @map("published_at")
  createdById     String        @map("created_by_id")
  updatedById     String?       @map("updated_by_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  // Relations
  category   NewsCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy  User              @relation("NewsCreator", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy  User?             @relation("NewsUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  highlights NewsHighlight[]
  tags       NewsTagRelation[]
  views      NewsView[]

  @@index([slug])
  @@index([categoryId])
  @@index([status])
  @@index([newsDate])
  @@index([publishedAt])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("news")
}

model NewsCategory {
  id          String    @id @default(uuid())
  nameEn      String    @map("name_en")
  nameId      String?   @map("name_id")
  slug        String    @unique
  description String?   @db.Text
  position    Int       @default(0)
  isActive    Boolean   @default(true) @map("is_active")
  createdById String?   @map("created_by")
  updatedById String?   @map("updated_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  news News[]

  @@index([slug])
  @@index([position])
  @@index([isActive])
  @@index([deletedAt])
  @@map("news_categories")
}

model NewsHighlight {
  id        String   @id @default(uuid())
  newsId    String   @unique @map("news_id")
  position  Int      @unique @default(0)
  createdById String? @map("created_by")
  updatedById String? @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  news News @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@index([newsId])
  @@index([position])
  @@map("news_highlights")
}

model NewsView {
  id        String   @id @default(uuid())
  newsId    String   @map("news_id")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  news News @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@index([newsId])
  @@index([ipAddress])
  @@map("news_views")
}

model NewsTag {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  news NewsTagRelation[]

  @@index([slug])
  @@index([deletedAt])
  @@map("news_tags")
}

model NewsTagRelation {
  id        String   @id @default(uuid())
  newsId    String   @map("news_id")
  tagId     String   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  news News    @relation(fields: [newsId], references: [id], onDelete: Cascade)
  tag  NewsTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([newsId, tagId])
  @@index([newsId])
  @@index([tagId])
  @@map("news_tag_relations")
}

// ============================================
// DOCUMENTS MODULE (3-TIER: ANNOUNCEMENTS)
// ============================================

model AnnouncementType {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  icon        String?
  color       String?
  position    Int       @default(0)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  sections AnnouncementSection[]

  @@index([slug])
  @@index([position])
  @@index([isActive])
  @@index([deletedAt])
  @@map("announcement_types")
}

model AnnouncementSection {
  id          String    @id @default(uuid())
  typeId      String    @map("type_id")
  name        String
  slug        String
  description String?   @db.Text
  position    Int       @default(0)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  type  AnnouncementType @relation(fields: [typeId], references: [id], onDelete: Cascade)
  items Announcement[]

  @@unique([typeId, slug])
  @@index([typeId])
  @@index([slug])
  @@index([position])
  @@index([isActive])
  @@index([deletedAt])
  @@map("announcement_sections")
}

model Announcement {
  id          String        @id @default(uuid())
  sectionId   String        @map("section_id")
  title       String
  slug        String
  description String?       @db.Text
  content     String?       @db.Text
  fileUrl     String?       @map("file_url")
  fileSize    Int?          @map("file_size")
  fileType    String?       @map("file_type")
  thumbnail   String?
  downloads   Int           @default(0)
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?     @map("published_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  // Relations
  section AnnouncementSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, slug])
  @@index([sectionId])
  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("announcements")
}

// ============================================
// REPORTS MODULE (3-TIER)
// ============================================

model ReportType {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  icon        String?
  color       String?
  position    Int       @default(0)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  sections ReportSection[]

  @@index([slug])
  @@index([position])
  @@index([isActive])
  @@index([deletedAt])
  @@map("report_types")
}

model ReportSection {
  id          String    @id @default(uuid())
  typeId      String    @map("type_id")
  name        String
  slug        String
  description String?   @db.Text
  position    Int       @default(0)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  type    ReportType @relation(fields: [typeId], references: [id], onDelete: Cascade)
  reports Report[]

  @@unique([typeId, slug])
  @@index([typeId])
  @@index([slug])
  @@index([position])
  @@index([isActive])
  @@index([deletedAt])
  @@map("report_sections")
}

model Report {
  id          String        @id @default(uuid())
  sectionId   String        @map("section_id")
  title       String
  slug        String
  description String?       @db.Text
  period      String?
  year        Int?
  quarter     Int?
  fileUrl     String?       @map("file_url")
  fileSize    Int?          @map("file_size")
  fileType    String?       @map("file_type")
  thumbnail   String?
  downloads   Int           @default(0)
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?     @map("published_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  // Relations
  section ReportSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, slug])
  @@index([sectionId])
  @@index([slug])
  @@index([year])
  @@index([quarter])
  @@index([status])
  @@index([publishedAt])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("reports")
}

// ============================================
// HR MODULE
// ============================================

model Career {
  id               String         @id @default(uuid())
  title            String
  slug             String         @unique
  department       String
  location         String
  employmentType   EmploymentType @default(FULL_TIME) @map("employment_type")
  description      String         @db.Text
  requirements     String         @db.Text
  responsibilities String         @db.Text
  benefits         String?        @db.Text
  salaryRange      String?        @map("salary_range")
  closingDate      DateTime?      @map("closing_date")
  status           CareerStatus   @default(OPEN)
  views            Int            @default(0)
  applications     Int            @default(0)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  deletedAt        DateTime?      @map("deleted_at")

  @@index([slug])
  @@index([department])
  @@index([status])
  @@index([closingDate])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("careers")
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum CareerStatus {
  OPEN
  CLOSED
  DRAFT
}

model Award {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  description String?   @db.Text
  image       String?
  issuer      String
  year        Int // Using year instead of issueDate for simplicity
  issueDate   DateTime  @map("issue_date") // Keep for backward compatibility
  position    Int       @default(0)
  isActive    Boolean   @default(true) @map("is_active")
  status      String    @default("ACTIVE") // ACTIVE, INACTIVE for better compatibility
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([slug])
  @@index([year])
  @@index([position])
  @@index([issueDate])
  @@index([isActive])
  @@index([status])
  @@index([deletedAt])
  @@map("awards")
}

model Management {
  id          String    @id @default(uuid())
  categoryId  String    @map("category_id")
  name        String
  slug        String    @unique
  position    String
  description String?   @db.Text
  photo       String?
  email       String?
  phone       String?
  linkedin    String?
  order       Int       @default(0)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  category ManagementCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([categoryId])
  @@index([slug])
  @@index([order])
  @@index([isActive])
  @@index([deletedAt])
  @@map("managements")
}

model ManagementCategory {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  position    Int       @default(0)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  managements Management[]

  @@index([slug])
  @@index([position])
  @@index([isActive])
  @@index([deletedAt])
  @@map("management_categories")
}

// ============================================
// COMMUNICATION MODULE
// ============================================

model ContactSubmission {
  id        String           @id @default(uuid())
  userId    String?          @map("user_id")
  name      String
  email     String
  phone     String?
  subject   String
  message   String           @db.Text
  type      ContactType      @default(GENERAL)
  status    SubmissionStatus @default(NEW)
  ipAddress String?          @map("ip_address")
  userAgent String?          @map("user_agent")
  readAt    DateTime?        @map("read_at")
  repliedAt DateTime?        @map("replied_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  deletedAt DateTime?        @map("deleted_at")

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("contact_submissions")
}

enum ContactType {
  GENERAL
  SUPPORT
  SALES
  PARTNERSHIP
  COMPLAINT
}

enum SubmissionStatus {
  NEW
  READ
  REPLIED
  CLOSED
}

// ============================================
// SYSTEM MODULE
// ============================================

model LogActivity {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")
  action      String // create, update, delete, login, logout, etc.
  module      String // users, news, pages, roles, permissions, etc.
  recordId    String?   @map("record_id") // ID of the affected record
  oldData     Json?     @map("old_data") // Previous state (for updates/deletes)
  newData     Json?     @map("new_data") // New state (for creates/updates)
  description String?   @db.Text
  metadata    Json? // Additional context/metadata
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at") // Soft delete for logs

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([recordId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("log_activities")
}

model UrlRedirect {
  id         String    @id @default(uuid())
  fromUrl    String    @unique @map("from_url")
  toUrl      String    @map("to_url")
  statusCode Int       @default(301) @map("status_code")
  hits       Int       @default(0)
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([fromUrl])
  @@index([isActive])
  @@index([deletedAt])
  @@map("url_redirects")
}

// ============================================
// FILES MODULE (Cloud Storage Metadata)
// ============================================

model Folder {
  id        String    @id @default(uuid())
  parentId  String?   @map("parent_id")
  name      String
  slug      String
  path      String    @unique
  isPublic  Boolean   @default(false) @map("is_public")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Self-referencing relation for hierarchical structure
  parent   Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[] @relation("FolderHierarchy")
  files    File[]

  @@index([parentId])
  @@index([path])
  @@index([deletedAt])
  @@map("folders")
}

model File {
  id            String    @id @default(uuid())
  folderId      String?   @map("folder_id")
  createdById   String    @map("created_by_id")
  name          String
  originalName  String    @map("original_name")
  mimeType      String    @map("mime_type")
  size          Int
  path          String
  url           String
  cloudProvider String?   @map("cloud_provider")
  cloudPath     String?   @map("cloud_path")
  cloudKey      String?   @map("cloud_key")
  thumbnail     String?
  thumbnails    Json? // {small: url, medium: url, large: url}
  width         Int?
  height        Int?
  duration      Int?
  metadata      Json?
  downloads     Int       @default(0)
  isPublic      Boolean   @default(false) @map("is_public")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  // Relations
  folder    Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdBy User    @relation("FileCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([folderId])
  @@index([createdById])
  @@index([mimeType])
  @@index([path])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("files")
}

// ============================================
// CONTACT US MODULE
// ============================================

model ContactUs {
  id          String        @id @default(uuid())
  firstName   String        @map("first_name")
  lastName    String        @map("last_name")
  email       String
  phone       String?
  role        String?
  company     String?
  inquiryType InquiryType   @map("inquiry_type")
  message     String        @db.Text
  status      ContactStatus @default(NEW)
  ipAddress   String?       @map("ip_address")
  userAgent   String?       @map("user_agent") @db.Text
  readAt      DateTime?     @map("read_at")
  submittedAt DateTime      @default(now()) @map("submitted_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([email])
  @@index([inquiryType])
  @@index([status])
  @@index([submittedAt])
  @@index([createdAt])
  @@map("contact_us")
}

enum InquiryType {
  BUSINESS
  SUPPORT
  CAREER
  OTHERS
}

enum ContactStatus {
  NEW
  READ
}
