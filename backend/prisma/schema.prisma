generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                             String              @id @default(uuid())
  email                          String              @unique
  username                       String              @unique
  password                       String
  firstName                      String              @map("first_name")
  lastName                       String              @map("last_name")
  avatar                         String?
  phone                          String?
  status                         UserStatus          @default(ACTIVE)
  emailVerifiedAt                DateTime?           @map("email_verified_at")
  lastLoginAt                    DateTime?           @map("last_login_at")
  failedLoginAttempts            Int                 @default(0) @map("failed_login_attempts")
  lockedAt                       DateTime?           @map("locked_at")
  lockedReason                   String?             @map("locked_reason")
  passwordChangedAt              DateTime            @default(now()) @map("password_changed_at")
  mustChangePassword             Boolean             @default(true) @map("must_change_password")
  mfaEnabled                     Boolean             @default(false) @map("mfa_enabled")
  mfaSecret                      String?             @map("mfa_secret")
  mfaVerifiedAt                  DateTime?           @map("mfa_verified_at")
  createdAt                      DateTime            @default(now()) @map("created_at")
  updatedAt                      DateTime            @updatedAt @map("updated_at")
  deletedAt                      DateTime?           @map("deleted_at")
  contactSubmissions             ContactSubmission[]
  createdFiles                   File[]              @relation("FileCreator")
  logActivities                  LogActivity[]
  news_news_created_by_idTousers news[]              @relation("news_created_by_idTousers")
  news_news_updated_by_idTousers news[]              @relation("news_updated_by_idTousers")
  createdPages                   Page[]              @relation("PageCreator")
  passwordHistories              PasswordHistory[]
  refreshTokens                  RefreshToken[]
  userRoles                      UserRole[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenId   String   @unique @map("token_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([token])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model PasswordHistory {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("password_histories")
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  slug            String           @unique
  description     String?
  isSystem        Boolean          @default(false) @map("is_system")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([slug])
  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  slug            String           @unique
  module          String
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]

  @@index([module])
  @@index([slug])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Setting {
  id          String      @id @default(uuid())
  key         String      @unique
  value       Json
  type        SettingType @default(STRING)
  group       String
  label       String
  description String?
  isPublic    Boolean     @default(false) @map("is_public")
  isSystem    Boolean     @default(false) @map("is_system")
  options     Json?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([group])
  @@index([key])
  @@index([isPublic])
  @@map("settings")
}

model Menu {
  id           BigInt       @id @default(autoincrement())
  parentId     BigInt?      @map("parent_id")
  sectionTitle String?      @map("section_title") @db.VarChar(191)
  sectionOrder Int          @default(0) @map("section_order")
  title        String       @db.VarChar(191)
  translations Json?
  slug         String?      @db.VarChar(191)
  url          String?      @db.VarChar(191)
  icon         String?      @db.VarChar(191)
  image        String?      @db.VarChar(191)
  description  String?      @db.VarChar(191)
  badge        String?      @db.VarChar(191)
  position     MenuPosition @default(HEADER)
  type         MenuType     @default(LINK)
  order        Int          @default(0)
  isActive     Boolean      @default(true) @map("is_active")
  openNewTab   Boolean      @default(false) @map("open_new_tab")
  cssClass     String?      @map("css_class") @db.VarChar(191)
  createdBy    String?      @map("created_by") @db.VarChar(191)
  updatedBy    String?      @map("updated_by") @db.VarChar(191)
  createdAt    DateTime?    @default(now()) @map("created_at")
  updatedAt    DateTime?    @updatedAt @map("updated_at")
  parent       Menu?        @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children     Menu[]       @relation("MenuHierarchy")

  @@index([parentId])
  @@index([position, order, isActive])
  @@map("menus")
}

model Page {
  id              String          @id @default(uuid())
  title           String
  slug            String          @unique
  template        PageTemplate    @default(DEFAULT)
  metaTitle       String?         @map("meta_title")
  metaDescription String?         @map("meta_description")
  metaKeywords    String?         @map("meta_keywords")
  ogImage         String?         @map("og_image")
  status          PageStatus      @default(DRAFT)
  publishedAt     DateTime?       @map("published_at")
  createdById     String          @map("created_by_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")
  components      PageComponent[]
  createdBy       User            @relation("PageCreator", fields: [createdById], references: [id])

  @@index([slug])
  @@index([status])
  @@index([template])
  @@index([publishedAt])
  @@index([createdAt])
  @@index([createdById])
  @@index([deletedAt])
  @@map("pages")
}

model PageComponent {
  id        String   @id @default(uuid())
  pageId    String   @map("page_id")
  type      String   @map("component_type")
  data      Json     @map("component_data")
  order     Int      @default(0)
  isVisible Boolean  @default(true) @map("is_visible")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([order])
  @@index([type])
  @@map("page_components")
}

model Career {
  id               String         @id @default(uuid())
  title            String
  slug             String         @unique
  department       String
  location         String
  employmentType   EmploymentType @default(FULL_TIME) @map("employment_type")
  description      String
  requirements     String
  responsibilities String
  benefits         String?
  salaryRange      String?        @map("salary_range")
  closingDate      DateTime?      @map("closing_date")
  status           CareerStatus   @default(OPEN)
  views            Int            @default(0)
  applications     Int            @default(0)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  deletedAt        DateTime?      @map("deleted_at")

  @@index([slug])
  @@index([department])
  @@index([status])
  @@index([closingDate])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("careers")
}

model Award {
  id              String    @id @default(uuid())
  title           String
  titleId         String?   @map("title_id")
  titleEn         String?   @map("title_en")
  slug            String    @unique
  description     String?
  descriptionId   String?   @map("description_id")
  descriptionEn   String?   @map("description_en")
  image           String?
  link            String?
  issuer          String
  year            Int
  issueDate       DateTime  @map("issue_date")
  position        Int       @default(0)
  isActive        Boolean   @default(true) @map("is_active")
  status          String    @default("ACTIVE")
  createdBy       String?   @map("created_by")
  updatedBy       String?   @map("updated_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  @@index([slug])
  @@index([year])
  @@index([position])
  @@index([issueDate])
  @@index([isActive])
  @@index([status])
  @@index([deletedAt])
  @@map("awards")
}

model ManagementCategory {
  id          String       @id
  name        String
  slug        String       @unique
  description String?
  position    Int          @default(0)
  is_active   Boolean      @default(true)
  createdBy   String?      @map("created_by")
  updatedBy   String?      @map("updated_by")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deleted_at  DateTime?
  managements Management[]

  @@index([slug])
  @@index([deleted_at])
  @@index([is_active])
  @@index([position])
  @@map("management_categories")
}

model Management {
  id                 String             @id
  categoryId         String             @map("category_id")
  name               String
  slug               String             @unique
  positionEn         String?            @map("position_en")
  positionId         String?            @map("position_id")
  description        String?
  photo              String?
  bioEn              String?            @map("bio_en")
  bioId              String?            @map("bio_id")
  email              String?
  phone              String?
  linkedin           String?
  order              Int                @default(0)
  is_active          Boolean            @default(true)
  createdBy          String?            @map("created_by")
  updatedBy          String?            @map("updated_by")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  deleted_at         DateTime?
  managementCategory ManagementCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([deleted_at])
  @@index([is_active])
  @@index([order])
  @@index([slug])
  @@map("managements")
}

model ContactSubmission {
  id        String           @id @default(uuid())
  userId    String?          @map("user_id")
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  type      ContactType      @default(GENERAL)
  status    SubmissionStatus @default(NEW)
  ipAddress String?          @map("ip_address")
  userAgent String?          @map("user_agent")
  readAt    DateTime?        @map("read_at")
  repliedAt DateTime?        @map("replied_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  deletedAt DateTime?        @map("deleted_at")
  user      User?            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("contact_submissions")
}

model LogActivity {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")
  action      String
  module      String
  recordId    String?   @map("record_id")
  oldData     Json?     @map("old_data")
  newData     Json?     @map("new_data")
  description String?
  metadata    Json?
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")
  user        User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([recordId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("log_activities")
}

model VisitorLog {
  id         String   @id @default(uuid())
  page       String
  referrer   String?
  userAgent  String?  @map("user_agent")
  ipAddress  String?  @map("ip_address")
  sessionId  String?  @map("session_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([page])
  @@index([createdAt])
  @@index([sessionId])
  @@map("visitor_logs")
}

model UrlRedirect {
  id         String    @id @default(uuid())
  fromUrl    String    @unique @map("from_url")
  toUrl      String    @map("to_url")
  statusCode Int       @default(301) @map("status_code")
  hits       Int       @default(0)
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([fromUrl])
  @@index([isActive])
  @@index([deletedAt])
  @@map("url_redirects")
}

model Folder {
  id        String    @id @default(uuid())
  parentId  String?   @map("parent_id")
  name      String
  slug      String
  path      String    @unique
  isPublic  Boolean   @default(false) @map("is_public")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  files     File[]
  parent    Folder?   @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[]  @relation("FolderHierarchy")

  @@index([parentId])
  @@index([path])
  @@index([deletedAt])
  @@map("folders")
}

model File {
  id            String    @id @default(uuid())
  folderId      String?   @map("folder_id")
  createdById   String    @map("created_by_id")
  name          String
  originalName  String    @map("original_name")
  mimeType      String    @map("mime_type")
  size          Int
  path          String
  url           String
  cloudProvider String?   @map("cloud_provider")
  cloudPath     String?   @map("cloud_path")
  cloudKey      String?   @map("cloud_key")
  thumbnail     String?
  thumbnails    Json?
  width         Int?
  height        Int?
  duration      Int?
  metadata      Json?
  downloads     Int       @default(0)
  isPublic      Boolean   @default(false) @map("is_public")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  createdBy     User      @relation("FileCreator", fields: [createdById], references: [id])
  folder        Folder?   @relation(fields: [folderId], references: [id])

  @@index([folderId])
  @@index([createdById])
  @@index([mimeType])
  @@index([path])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("files")
}

model ContactUs {
  id          String        @id @default(uuid())
  firstName   String        @map("first_name")
  lastName    String        @map("last_name")
  email       String
  phone       String?
  role        String?
  company     String?
  inquiryType InquiryType   @map("inquiry_type")
  message     String
  status      ContactStatus @default(NEW)
  ipAddress   String?       @map("ip_address")
  userAgent   String?       @map("user_agent")
  readAt      DateTime?     @map("read_at")
  submittedAt DateTime      @default(now()) @map("submitted_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([email])
  @@index([inquiryType])
  @@index([status])
  @@index([submittedAt])
  @@index([createdAt])
  @@map("contact_us")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model CareerContent {
  id             BigInt    @id @default(autoincrement())
  position       String    @db.VarChar(255)
  slug           String?   @db.VarChar(255)
  division       String?   @db.VarChar(255)
  type           String?   @db.VarChar(100)
  linkJob        String?   @map("link_job") @db.VarChar(500)
  location       String?   @db.VarChar(255)
  description    String?
  descriptionId  String?   @map("description_id")
  requirements   String?
  requirementsId String?   @map("requirements_id")
  status         String    @default("active") @db.VarChar(20)
  expiryDate     DateTime? @map("expiry_date") @db.Timestamp(6)
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime? @default(now()) @map("updated_at") @db.Timestamp(0)
  createdBy      String?   @map("created_by") @db.VarChar(255)
  updatedBy      String?   @map("updated_by") @db.VarChar(255)

  @@index([createdAt(sort: Desc)], map: "idx_career_content_created_at_desc")
  @@index([division], map: "idx_career_content_division")
  @@index([expiryDate], map: "idx_career_content_expiry_date")
  @@index([location], map: "idx_career_content_location")
  @@index([status], map: "idx_career_content_status")
  @@index([type], map: "idx_career_content_type")
  @@map("career_content")
}

model ReportType {
  id              String          @id
  name            String
  slug            String          @unique
  description     String?
  icon            String?
  color           String?
  position        Int             @default(0)
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")
  report_sections ReportSection[]
  reports         reports[]

  @@index([isActive])
  @@index([deletedAt])
  @@index([position])
  @@index([slug])
  @@map("report_types")
}

model ReportSection {
  id           String     @id
  type_id      String
  name         String
  slug         String
  description  String?
  position     Int        @default(0)
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")
  report_types ReportType @relation(fields: [type_id], references: [id], onDelete: Cascade)
  reports      reports[]

  @@unique([type_id, slug])
  @@index([isActive])
  @@index([deletedAt])
  @@index([position])
  @@index([slug])
  @@index([type_id])
  @@map("report_sections")
}

model news {
  id                              String               @id
  title_en                        String
  title_id                        String?
  slug                            String               @unique
  news_date                       DateTime             @db.Date
  news_thumbnail                  String?
  excerpt_en                      String?
  excerpt_id                      String?
  content_en                      String
  content_id                      String?
  news_link                       String?
  author                          String?
  meta_desc                       String?
  category_id                     String
  meta_keywords                   String?
  custom_css                      String?
  custom_js                       String?
  view_count                      Int                  @default(0)
  view_count_unique               Int                  @default(0)
  status                          ContentStatus        @default(DRAFT)
  published_at                    DateTime?
  created_by_id                   String
  updated_by_id                   String?
  created_at                      DateTime             @default(now())
  updated_at                      DateTime
  deleted_at                      DateTime?
  news_categories                 news_categories      @relation(fields: [category_id], references: [id])
  users_news_created_by_idTousers User                 @relation("news_created_by_idTousers", fields: [created_by_id], references: [id])
  users_news_updated_by_idTousers User?                @relation("news_updated_by_idTousers", fields: [updated_by_id], references: [id])
  news_highlights                 news_highlights?
  news_tag_relations              news_tag_relations[]
  news_views                      news_views[]

  @@index([category_id])
  @@index([created_at])
  @@index([deleted_at])
  @@index([news_date])
  @@index([published_at])
  @@index([slug])
  @@index([status])
}

model news_categories {
  id          String    @id
  name_en     String
  name_id     String?
  slug        String    @unique
  description String?
  position    Int       @default(0)
  is_active   Boolean   @default(true)
  created_by  String?
  updated_by  String?
  created_at  DateTime  @default(now())
  updated_at  DateTime
  deleted_at  DateTime?
  news        news[]

  @@index([deleted_at])
  @@index([is_active])
  @@index([position])
  @@index([slug])
}

model news_highlights {
  id         String   @id
  news_id    String   @unique
  position   Int      @unique @default(0)
  created_by String?
  updated_by String?
  created_at DateTime @default(now())
  updated_at DateTime
  news       news     @relation(fields: [news_id], references: [id], onDelete: Cascade)

  @@index([news_id])
  @@index([position])
}

model news_tag_relations {
  id         String    @id
  news_id    String
  tag_id     String
  created_at DateTime  @default(now())
  news       news      @relation(fields: [news_id], references: [id], onDelete: Cascade)
  news_tags  news_tags @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@unique([news_id, tag_id])
  @@index([news_id])
  @@index([tag_id])
}

model news_tags {
  id                 String               @id
  name               String
  slug               String               @unique
  created_at         DateTime             @default(now())
  updated_at         DateTime
  deleted_at         DateTime?
  news_tag_relations news_tag_relations[]

  @@index([deleted_at])
  @@index([slug])
}

model news_views {
  id         String   @id
  news_id    String
  ip_address String?
  user_agent String?
  created_at DateTime @default(now())
  updated_at DateTime
  news       news     @relation(fields: [news_id], references: [id], onDelete: Cascade)

  @@index([ip_address])
  @@index([news_id])
}

model reports {
  id              String         @id
  type_id         String?
  section_id      String?
  title           String
  slug            String
  description     String?
  pdf_file        String?
  cover_image     String?
  data_type       String?
  audit_status    String?
  file_size       String?
  sort_order      Int            @default(0)
  is_active       Boolean        @default(true)
  period          String?
  year            Int?
  quarter         Int?
  file_url        String?
  file_type       String?
  thumbnail       String?
  downloads       Int            @default(0)
  status          ContentStatus  @default(DRAFT)
  published_at    DateTime?
  created_at      DateTime       @default(now())
  updated_at      DateTime
  deleted_at      DateTime?
  report_types    ReportType?    @relation(fields: [type_id], references: [id], onDelete: Cascade)
  report_sections ReportSection? @relation(fields: [section_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([deleted_at])
  @@index([published_at])
  @@index([quarter])
  @@index([section_id])
  @@index([slug])
  @@index([sort_order])
  @@index([status])
  @@index([type_id])
  @@index([year])
}

// ============================================
// ANNOUNCEMENT MODULE
// ============================================

model AnnouncementType {
  id                     String                @id
  name                   String
  slug                   String                @unique
  type                   String                @default("List")
  description            String?
  icon                   String?
  color                  String?
  position               Int                   @default(0)
  isActive               Boolean               @default(true) @map("is_active")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")
  deletedAt              DateTime?             @map("deleted_at")
  announcement_sections  AnnouncementSection[]
  announcements          announcements[]

  @@index([isActive])
  @@index([deletedAt])
  @@index([position])
  @@index([slug])
  @@map("announcement_types")
}

model AnnouncementSection {
  id                    String             @id
  type_id               String
  name                  String
  slug                  String
  description           String?
  announcement_year     String?
  cta_enabled           Boolean            @default(false)
  cta_text              String?
  cta_url               String?
  position              Int                @default(0)
  isActive              Boolean            @default(true) @map("is_active")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  deletedAt             DateTime?          @map("deleted_at")
  announcement_types    AnnouncementType   @relation(fields: [type_id], references: [id], onDelete: Cascade)
  announcements         announcements[]

  @@unique([type_id, slug])
  @@index([isActive])
  @@index([deletedAt])
  @@index([position])
  @@index([slug])
  @@index([type_id])
  @@map("announcement_sections")
}

model announcements {
  id                      String              @id
  type_id                 String?
  section_id              String?
  title                   String
  slug                    String
  description             String?
  pdf_file                String?
  cover_image             String?
  data_type               String?
  audit_status            String?
  file_size               String?
  sort_order              Int                 @default(0)
  is_active               Boolean             @default(true)
  status                  ContentStatus       @default(PUBLISHED)
  created_at              DateTime            @default(now())
  updated_at              DateTime
  deleted_at              DateTime?
  announcement_types      AnnouncementType?   @relation(fields: [type_id], references: [id], onDelete: Cascade)
  announcement_sections   AnnouncementSection? @relation(fields: [section_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([deleted_at])
  @@index([section_id])
  @@index([slug])
  @@index([sort_order])
  @@index([status])
  @@index([type_id])
}

