{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Image Gallery",
  "description": "Gallery of images with captions",
  "properties": {
    "images": {
      "type": "array",
      "title": "Images",
      "description": "Gallery images",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "title": "Image URL",
            "format": "uri"
          },
          "caption": {
            "type": "string",
            "title": "Caption",
            "maxLength": 200
          },
          "alt": {
            "type": "string",
            "title": "Alt Text",
            "description": "Alternative text for accessibility",
            "maxLength": 150
          }
        },
        "required": ["url", "alt"]
      },
      "minItems": 1
    }
  },
  "required": ["images"],
  "additionalProperties": false
}
