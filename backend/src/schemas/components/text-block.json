{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Text Block",
  "description": "Rich text content block with WYSIWYG editor",
  "properties": {
    "content": {
      "type": "string",
      "title": "Content",
      "description": "HTML content from WYSIWYG editor",
      "contentMediaType": "text/html"
    }
  },
  "required": ["content"],
  "additionalProperties": false
}
