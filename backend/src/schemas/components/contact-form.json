{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Contact Form",
  "description": "Contact form embed reference",
  "required": ["form_id"],
  "properties": {
    "form_id": {
      "type": "string",
      "title": "Form ID",
      "description": "Contact form identifier or configuration ID"
    },
    "title": {
      "type": "string",
      "title": "Form Title",
      "description": "Heading displayed above form"
    },
    "description": {
      "type": "string",
      "title": "Description",
      "description": "Text displayed below title"
    },
    "show_title": {
      "type": "boolean",
      "title": "Show Title",
      "description": "Display the form title",
      "default": true
    },
    "success_message": {
      "type": "string",
      "title": "Success Message",
      "description": "Message shown after successful submission",
      "default": "Thank you! We'll get back to you soon."
    }
  }
}
