# Application
NODE_ENV=development
PORT=5000
HOST=localhost
API_PREFIX=/api/v1
API_VERSION=1.0.0

# Database (PostgreSQL with Prisma)
DATABASE_URL="postgresql://username:password@localhost:5432/linknetcorp?schema=public"

# JWT Authentication
# IMPORTANT: Generate strong random secrets for production (min 32 characters)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your-super-secret-jwt-access-key-min-32-chars-change-in-production
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-min-32-chars-change-in-production
JWT_REFRESH_EXPIRE=7d

# Legacy support (will use JWT_ACCESS_SECRET if not set)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM_NAME=LinkNet Corp
EMAIL_FROM_ADDRESS=noreply@linknetcorp.co.id

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Cloud Storage (Optional)
# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=

# Or Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_DIR=logs
ENABLE_FILE_LOGS=false

# Redis (Optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ================================
# Azure Key Vault Configuration
# ================================
# Azure Key Vault URL (optional - for production)
# Example: https://your-vault-name.vault.azure.net/
AZURE_KEY_VAULT_URL=

# Azure AD Authentication (for local development with service principal)
# Leave empty to use Managed Identity in production (AKS)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Google reCAPTCHA (Optional)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
