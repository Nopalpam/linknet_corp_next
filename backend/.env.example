# ============================================================
# BACKEND — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# ⚠  Never commit .env (with real values) to version control.
#    In production, all secrets must be stored in Azure Key Vault.
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
HOST=localhost
API_PREFIX=/api/v1
API_VERSION=1.0.0
BASE_URL=http://localhost:5000

# ── Database (PostgreSQL via Prisma) ─────────────────────────
# ⚠  KEY VAULT: DATABASE_URL (password)
DATABASE_URL="postgresql://username:password@localhost:5432/linknetcoid?schema=public"

# ── JWT Authentication ────────────────────────────────────────
# ⚠  KEY VAULT: JWT_ACCESS_SECRET, JWT_REFRESH_SECRET
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRE=7d

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true
FRONTEND_URL=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# false in development, true in production
RATE_LIMIT_ENABLED=false

# ── Security ─────────────────────────────────────────────────
# false in development, true in production (behind HTTPS load balancer)
FORCE_HTTPS=false

# ── File Upload & Storage ─────────────────────────────────────
# STORAGE_DRIVER: local | azure | s3
STORAGE_DRIVER=local
# Max upload size in bytes (default: 10 MB)
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# ── AWS S3 (required when STORAGE_DRIVER=s3) ─────────────────
# ⚠  KEY VAULT: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# Optional CDN/CloudFront prefix URL (no trailing slash)
AWS_S3_PUBLIC_URL=
# Optional custom S3-compatible endpoint (MinIO, DO Spaces, etc.)
AWS_S3_ENDPOINT=
# notes:
# fiberco prd dhxx16rg93rww.cloudfront.net
# enterprise prd d18uoa8psnnuug.cloudfront.net

# ── Azure Blob Storage (required when STORAGE_DRIVER=azure) ──
# ⚠  KEY VAULT: AZURE_STORAGE_CONNECTION_STRING, AZURE_STORAGE_ACCOUNT_NAME
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONTAINER_NAME=uploads

# ── Azure Key Vault (production secret injection) ─────────────
# Example: https://your-vault-name.vault.azure.net/
# Leave empty to skip Key Vault and use direct env vars
AZURE_KEY_VAULT_URL=
# Leave empty to use Managed Identity in production (AKS/App Service)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
# ⚠  KEY VAULT: AZURE_CLIENT_SECRET
AZURE_CLIENT_SECRET=

# ── MFA ──────────────────────────────────────────────────────
MFA_ENABLED=false
MFA_APP_NAME=LinkNet Corp CMS

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs
ENABLE_FILE_LOGS=false

# ── Redis (optional caching) ─────────────────────────────────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
# ⚠  KEY VAULT: REDIS_PASSWORD
REDIS_PASSWORD=
REDIS_DB=0

# ── Google Analytics 4 ───────────────────────────────────────
GA4_PROPERTY_ID=
# ⚠  KEY VAULT: GOOGLE_SERVICE_ACCOUNT_JSON
# Full service account JSON (minified). Get from Google Cloud Console → Service Accounts → Keys.
# Run: cat key.json | python -c "import json,sys; print(json.dumps(json.load(sys.stdin)))"
GOOGLE_SERVICE_ACCOUNT_JSON=
# Alternatif: individual credentials (hanya jika tidak menggunakan GOOGLE_SERVICE_ACCOUNT_JSON)
# ⚠  KEY VAULT: GA4_CLIENT_EMAIL, GA4_PRIVATE_KEY
# GA4_CLIENT_EMAIL=
# GA4_PRIVATE_KEY=

# ── Settings Encryption ───────────────────────────────────────
# Key used to encrypt sensitive settings stored in the database.
# ⚠  KEY VAULT: SETTINGS_ENCRYPTION_KEY
SETTINGS_ENCRYPTION_KEY=

# ── Enterprise API ────────────────────────────────────────────
# ⚠  REQUIRED — app will fail to start if ENTERPRISE_CLIENT_SECRET
#    or ENTERPRISE_PASSWORD are missing (no hardcoded fallbacks).
# ⚠  KEY VAULT: ENTERPRISE_CLIENT_SECRET, ENTERPRISE_PASSWORD
ENTERPRISE_CLIENT_ID=servco
ENTERPRISE_CLIENT_SECRET=
ENTERPRISE_USERNAME=lmi
ENTERPRISE_PASSWORD=
ENTERPRISE_PARTNER_ID=100

# ── Preview / Revalidation (Next.js ISR) ─────────────────────
# ⚠  KEY VAULT: PREVIEW_SECRET, REVALIDATE_SECRET
PREVIEW_SECRET=
REVALIDATE_SECRET=
NEXTJS_URL=http://localhost:3000

# ============================================================
# REMOVED VARIABLES (no longer in use)
# ============================================================
# SESSION_SECRET         — backend uses JWT, not sessions; removed
# SMTP_HOST/PORT/USER/PASS — email.util.ts is a mock; no SMTP used
# EMAIL_FROM_NAME/ADDRESS — not used in current email code
# STORAGE_TYPE           — alias for STORAGE_DRIVER; standardized
# AZURE_STORAGE_CONTAINER — alias for AZURE_STORAGE_CONTAINER_NAME; standardized
# RECAPTCHA_SITE_KEY/SECRET_KEY — not used in backend code
# DISABLE_RATE_LIMIT     — legacy; use RATE_LIMIT_ENABLED=false instead
# JWT_SECRET             — legacy; use JWT_ACCESS_SECRET
# JWT_EXPIRES_IN         — legacy; use JWT_ACCESS_EXPIRE
# JWT_REFRESH_EXPIRES_IN — legacy; use JWT_REFRESH_EXPIRE
# UPLOAD_PATH            — alias for UPLOAD_DIR; standardized
# NEXT_PUBLIC_AUTH_ENABLED — belongs to frontend service, not backend
# NEXT_PUBLIC_API_URL    — belongs to frontend service, not backend
# ============================================================
