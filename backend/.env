# ============================================================
# BACKEND — Local Development Environment
# ============================================================
# ⚠  File ini untuk LOCAL DEVELOPMENT saja. JANGAN commit ke VCS.
# ⚠  Untuk production, gunakan .env.production atau Azure Key Vault.
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
API_PREFIX=/api/v1
API_VERSION=1.0.0
BASE_URL=http://localhost:5000

# ── Database (PostgreSQL via Prisma) ─────────────────────────
# Sesuaikan user/password dengan setup PostgreSQL lokal kamu
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/linknetcoid_dev?schema=public

# ── JWT Authentication ────────────────────────────────────────
# Nilai di bawah hanya untuk dev — GANTI di production
JWT_ACCESS_SECRET=local_dev_access_secret_32chars_minimum_placeholder_only
JWT_SECRET=local_dev_access_secret_32chars_minimum_placeholder_only
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_SECRET=local_dev_refresh_secret_32chars_minimum_placeholder_only
JWT_REFRESH_EXPIRE=7d

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002
CORS_CREDENTIALS=true
FRONTEND_URL=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_ENABLED=false

# ── Security ─────────────────────────────────────────────────
FORCE_HTTPS=false

# ── File Upload & Storage ─────────────────────────────────────
# Gunakan 'local' untuk dev agar tidak perlu AWS/Azure
STORAGE_DRIVER=local
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# ── AWS S3 (tidak aktif saat STORAGE_DRIVER=local) ───────────
AWS_REGION=ap-southeast-3
AWS_ACCESS_KEY_ID=local_placeholder
AWS_SECRET_ACCESS_KEY=local_placeholder
AWS_S3_BUCKET=local_placeholder
AWS_S3_PUBLIC_URL=http://localhost:5000/uploads
AWS_S3_ENDPOINT=

# ── Azure Blob Storage (tidak aktif saat STORAGE_DRIVER=local) ─
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONTAINER_NAME=uploads
AZURE_STORAGE_CONTAINER=uploads

# ── Azure Key Vault (tidak dipakai di local) ──────────────────
AZURE_KEY_VAULT_URL=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── MFA ──────────────────────────────────────────────────────
MFA_ENABLED=false
MFA_APP_NAME=LinkNet Corp CMS

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=logs
ENABLE_FILE_LOGS=false
# ============================================================
# BACKEND — Environment Variables
# ============================================================
# Audited: 2026-04-23 | Siap dikirim ke Azure Key Vault
# Semua variable di file ini AKTIF digunakan oleh source code.
# ⚠  Jangan commit file ini ke version control.
# ⚠  Nilai bertanda <FILL> WAJIB diisi oleh tim IT sebelum deploy.
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=production
PORT=5000
HOST=0.0.0.0
API_PREFIX=/api/v1
API_VERSION=1.0.0
BASE_URL=https://api.linknet.co.id

# ── Database (PostgreSQL via Prisma) ─────────────────────────
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/linknetcoid?schema=public

# ── JWT Authentication ────────────────────────────────────────
# ⚠  KEY VAULT — Generate: node -e "require('crypto').randomBytes(64).toString('hex')"
# JWT_ACCESS_SECRET  : dipakai jwt.util.ts (primary token signing)
# JWT_SECRET         : dipakai config/index.ts (WAJIB sama nilainya dengan JWT_ACCESS_SECRET)
JWT_ACCESS_SECRET=<FILL: random hex 64 bytes>
JWT_SECRET=<FILL: sama dengan JWT_ACCESS_SECRET>
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_SECRET=<FILL: random hex 64 bytes, berbeda dari JWT_ACCESS_SECRET>
JWT_REFRESH_EXPIRE=7d

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=https://cms.linknet.co.id,https://linknet.co.id
CORS_CREDENTIALS=true
FRONTEND_URL=https://cms.linknet.co.id

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_ENABLED=true

# ── Security ─────────────────────────────────────────────────
FORCE_HTTPS=true

# ── File Upload & Storage ─────────────────────────────────────
# STORAGE_DRIVER: local | azure | s3
STORAGE_DRIVER=s3
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# ── AWS S3 (aktif saat STORAGE_DRIVER=s3) ────────────────────
AWS_REGION=ap-southeast-3
AWS_ACCESS_KEY_ID=<FILL: AWS access key ID>
AWS_SECRET_ACCESS_KEY=<FILL: AWS secret access key>
AWS_S3_BUCKET=<FILL: nama S3 bucket>
AWS_S3_PUBLIC_URL=<FILL: CloudFront/CDN URL, tanpa trailing slash>
AWS_S3_ENDPOINT=

# ── Azure Blob Storage (aktif saat STORAGE_DRIVER=azure) ─────
# ⚠  KEY VAULT: AZURE_STORAGE_CONNECTION_STRING
AZURE_STORAGE_CONNECTION_STRING=<FILL: Azure Storage connection string>
AZURE_STORAGE_ACCOUNT_NAME=<FILL: nama storage account>
# Dipakai oleh azureStorage.service.ts
AZURE_STORAGE_CONTAINER_NAME=uploads
# Dipakai oleh storage.util.ts (avatar upload — nama berbeda, nilai sama)
AZURE_STORAGE_CONTAINER=uploads

# ── Azure Key Vault ───────────────────────────────────────────
AZURE_KEY_VAULT_URL=<FILL: https://nama-vault.vault.azure.net/>
AZURE_TENANT_ID=<FILL: Azure tenant ID>
AZURE_CLIENT_ID=<FILL: service principal client ID>
AZURE_CLIENT_SECRET=<FILL: service principal client secret>

# ── MFA ──────────────────────────────────────────────────────
MFA_ENABLED=false
MFA_APP_NAME=LinkNet Corp CMS

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=warn
LOG_DIR=logs
ENABLE_FILE_LOGS=true

# ── Redis (opsional — aktifkan jika menggunakan Redis) ────────
REDIS_ENABLED=false
REDIS_HOST=<FILL jika REDIS_ENABLED=true>
REDIS_PORT=6379
REDIS_PASSWORD=<FILL jika REDIS_ENABLED=true>
REDIS_DB=0

# ── Google Analytics 4 ───────────────────────────────────────
GA4_PROPERTY_ID=273390082
# Gunakan inline credentials (Key Vault friendly) — JANGAN gunakan file path di production
GA4_CREDENTIALS_PATH=
GA4_CLIENT_EMAIL=<FILL: service account email dari Google Cloud>
GA4_PRIVATE_KEY=<FILL: private key PEM, format: "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n">

# ── Settings Encryption ───────────────────────────────────────
# ⚠  KEY VAULT — Generate: node -e "require('crypto').randomBytes(32).toString('hex')"
SETTINGS_ENCRYPTION_KEY=<FILL: random hex 32 bytes>

# ── Enterprise API (Linknet) ──────────────────────────────────
# ⚠  WAJIB diisi — kode akan error saat start jika kosong
ENTERPRISE_CLIENT_ID=servco
ENTERPRISE_CLIENT_SECRET=<FILL: enterprise API client secret>
ENTERPRISE_USERNAME=lmi
ENTERPRISE_PASSWORD=<FILL: enterprise API password>
ENTERPRISE_PARTNER_ID=100

# ── Preview & On-demand Revalidation ─────────────────────────
# Dipakai oleh public.controller.ts untuk draft preview dan cache revalidation
NEXTJS_URL=https://linknet.co.id
PREVIEW_SECRET=<FILL: random string, sama dengan yang dikonfigurasi di web/.env>
REVALIDATE_SECRET=<FILL: random string, sama dengan yang dikonfigurasi di web/.env>

# ── Preview / Revalidation (Next.js ISR) ─────────────────────
PREVIEW_SECRET=your-preview-secret-change-this-min-32-chars
REVALIDATE_SECRET=your-revalidate-secret-change-this-min-32-chars
NEXTJS_URL=http://localhost:3000

