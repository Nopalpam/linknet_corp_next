# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# NOTE: package-lock.json must NOT be excluded — npm ci requires it

# Build outputs (rebuilt inside container)
.next/
out/
dist/
build/

# Environment files — never bake secrets into the image
.env
.env.local
.env*.local

# Development / IDE
.vscode/
.idea/

# Git
.git/
.gitignore

# Testing
coverage/
.nyc_output/
__tests__/
*.test.*
*.spec.*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
.cache/

# CI / deploy config (not needed in image)
*.yml
*.yaml
Dockerfile*
.dockerignore
