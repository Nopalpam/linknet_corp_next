# ============================================================
# FRONTEND (Admin CMS) — Local Development Environment
# ============================================================
# ⚠  File ini untuk LOCAL DEVELOPMENT saja. JANGAN commit ke VCS.
# ⚠  Untuk production, gunakan .env.production atau Azure Key Vault.
# ============================================================

# Backend API base URL — arahkan ke backend lokal
NEXT_PUBLIC_API_URL=http://localhost:5000

# Nonaktifkan auth nyata di local agar bisa dev tanpa login
# Set true jika ingin test auth flow secara lokal
NEXT_PUBLIC_AUTH_ENABLED=true

# URL public website lokal (untuk tombol "View Page" di CMS)
NEXT_PUBLIC_SITE_URL=http://localhost:3001
# ============================================================
# FRONTEND (Admin CMS) — Environment Variables
# ============================================================
# Audited: 2026-04-23 | Siap dikirim ke Azure Key Vault
# ⚠  Jangan commit file ini ke version control.
# ⚠  Variabel NEXT_PUBLIC_* akan di-bundle ke client-side — jangan taruh secret di sini.
# ============================================================

# Backend API base URL (tanpa trailing slash)
# NEXT_PUBLIC_API_URL=https://api.linknet.co.id

# # Aktifkan autentikasi nyata (true = real API auth, false = mock/bypass untuk dev)
# NEXT_PUBLIC_AUTH_ENABLED=true

# # URL public website — dipakai untuk tombol "View Page" di admin CMS
# NEXT_PUBLIC_SITE_URL=https://linknet.co.id

