# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_API_TIMEOUT=30000

# App Configuration
NEXT_PUBLIC_APP_NAME=LinkNet Corp
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_DEBUG=true
NEXT_PUBLIC_AUTH_ENABLED=true

# External Services
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Analytics
NEXT_PUBLIC_GA_TRACKING_ID=UA-XXXXXXXXX-X
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Public Website URL (for View Page links - fallback if CMS settings not configured)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Image Optimization
NEXT_PUBLIC_IMAGE_DOMAIN=localhost

# Server-side only (not exposed to browser)
API_SECRET_KEY=your-server-side-secret
INTERNAL_API_TOKEN=your-internal-token

# Database (if using server-side rendering with direct DB access)
DATABASE_URL=mysql://user:password@localhost:3306/linknetcorp_db

# Session Secret
SESSION_SECRET=your-session-secret-change-in-production

# Email Service (server-side)
EMAIL_SERVICE_API_KEY=your-email-service-key

# Development Performance Optimizations
# Disable type checking during development (faster builds)
NEXT_DISABLE_TYPE_CHECKING=false

# Enable SWC minification
NEXT_TELEMETRY_DISABLED=1

# Faster builds
NEXT_PRIVATE_BUILD_WORKER=true
