# ===================================
# Authentication Configuration
# ===================================

# Enable/Disable Real Authentication
# Set to 'false' to bypass authentication (mock login for development)
# Set to 'true' to enable real authentication with Express.js backend
# 
# When AUTH_ENABLED = false:
#   - Any email/password will work (mock mode)
#   - No API calls to backend
#   - Useful for UI development without backend
#
# When AUTH_ENABLED = true:
#   - Real API authentication
#   - Requires backend running
#   - Full security features enabled
NEXT_PUBLIC_AUTH_ENABLED=true

# ===================================
# API Configuration
# ===================================

# Backend API Base URL
# This should point to your Express.js backend server
# Development: http://localhost:5000
# Production: https://your-api-domain.com
NEXT_PUBLIC_API_URL=https://api.linknet.co.id/api/v1

# Public Website Base URL
# Used for "View Page" links in the admin CMS
# Development: http://localhost:3001
# Production: https://your-public-site.com
NEXT_PUBLIC_SITE_URL=https://linknet.co.id

# Allowed remote image hosts for Next.js image optimization.
# Comma-separated hostnames; wildcard subdomains use *.example.com.
NEXT_IMAGE_REMOTE_HOSTS=linknet.co.id,www.linknet.co.id,api.linknet.co.id,*.cloudfront.net,*.amazonaws.com,*.blob.core.windows.net
